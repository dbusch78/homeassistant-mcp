# Home Assistant MCP Server Configuration
# Copy this file to .env and fill in your values

# ── Home Assistant connection ────────────────────────────────────────────────

# Home Assistant URL (include http:// or https://)
HA_URL=http://homeassistant.local:8123

# Home Assistant Long-Lived Access Token
# Get this from your Home Assistant Profile -> Long-lived access tokens
HA_TOKEN=

# Optional: Enable debug logging
# DEBUG=true

# ── Transport ────────────────────────────────────────────────────────────────
# stdio (default) is used by Claude Desktop and start_mcp.sh.
# http exposes a Streamable HTTP MCP endpoint for Claude Code and AI agents.
# MCP_TRANSPORT=http

# HTTP bind host/port/path (only used when MCP_TRANSPORT=http).
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_PORT=8787
# MCP_HTTP_PATH=/mcp

# ── HTTP security (DNS-rebinding protection) ─────────────────────────────────
# By default the server allows ONLY the exact bind address:
#   host 127.0.0.1 port 8787  ->  allowed Host  = "127.0.0.1:8787"
#                                 allowed Origin = "http://127.0.0.1:8787"
#
# ⚠️  IMPORTANT — localhost is NOT 127.0.0.1 here.
#     Connecting to http://localhost:8787 sends "Host: localhost:8787", which does
#     NOT match the default "127.0.0.1:8787" and is REJECTED with HTTP 421.
#     On a 127.0.0.1 bind, connect using the IP (http://127.0.0.1:8787), or add
#     "localhost:8787" to MCP_ALLOWED_HOSTS below. This trips people up — by design.
#
# Comma-separated overrides (REPLACE the auto-derived default when set):
# MCP_ALLOWED_HOSTS=127.0.0.1:8787,localhost:8787
# MCP_ALLOWED_ORIGINS=http://127.0.0.1:8787

# Bearer token required on every HTTP request (Authorization: Bearer <token>).
# Optional for a loopback bind; REQUIRED (along with MCP_ALLOWED_HOSTS) when
# MCP_HTTP_HOST is not loopback — the server refuses to start otherwise, so a
# misconfigured 0.0.0.0 bind can't silently expose Home Assistant control.
# MCP_AUTH_TOKEN=
